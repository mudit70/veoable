{
  "name": "@veoable/trace",
  "version": "0.3.0",
  "private": false,
  "description": "Runtime instrumentation library that records edges observed during test runs, so veoable analyze can merge them as fallback for static-analysis misses (#535).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  }
}
