{
  "name": "@adorable/graph-db",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external @adorable/schema --external @adorable/plugin-api",
    "dev": "tsup src/index.ts --format esm --dts --external @adorable/schema --external @adorable/plugin-api --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@adorable/plugin-api": "workspace:*",
    "@adorable/schema": "workspace:*",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
