{
  "name": "@adorable/agents",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external @adorable/core --external @adorable/graph-db",
    "dev": "tsup src/index.ts --format esm --dts --external @adorable/core --external @adorable/graph-db --watch"
  },
  "dependencies": {
    "@adorable/core": "workspace:*",
    "@adorable/graph-db": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
