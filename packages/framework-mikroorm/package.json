{
  "name": "@adorable/framework-mikroorm",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external @adorable/schema --external @adorable/plugin-api --external @adorable/lang-ts --external ts-morph",
    "dev": "tsup src/index.ts --format esm --dts --external @adorable/schema --external @adorable/plugin-api --external @adorable/lang-ts --external ts-morph --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@adorable/lang-ts": "workspace:*",
    "@adorable/plugin-api": "workspace:*",
    "@adorable/schema": "workspace:*",
    "ts-morph": "^27.0.0"
  },
  "devDependencies": {
    "@adorable/graph-db": "workspace:*",
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
