{
  "name": "@veoable/lang-java",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external @veoable/schema --external @veoable/plugin-api --external @veoable/observability --external web-tree-sitter",
    "dev": "tsup src/index.ts --format esm --dts --external @veoable/schema --external @veoable/plugin-api --external @veoable/observability --external web-tree-sitter --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@veoable/observability": "workspace:*",
    "@veoable/plugin-api": "workspace:*",
    "@veoable/schema": "workspace:*",
    "web-tree-sitter": "^0.26.10",
    "tree-sitter-wasms": "^0.1.13"
  },
  "devDependencies": {
    "@veoable/graph-db": "workspace:*",
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
