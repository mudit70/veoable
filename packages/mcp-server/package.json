{
  "name": "@adorable/mcp-server",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external @modelcontextprotocol/sdk --external @adorable/schema --external @adorable/plugin-api --external @adorable/graph-db --external @adorable/flow-stitcher --external @adorable/skill",
    "dev": "tsup src/index.ts --format esm --dts --external @modelcontextprotocol/sdk --external @adorable/schema --external @adorable/plugin-api --external @adorable/graph-db --external @adorable/flow-stitcher --external @adorable/skill --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@adorable/flow-stitcher": "workspace:*",
    "@adorable/graph-db": "workspace:*",
    "@adorable/plugin-api": "workspace:*",
    "@adorable/schema": "workspace:*",
    "@adorable/skill": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
