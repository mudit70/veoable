{
  "name": "@veoable/framework-redirects",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external @veoable/schema --external @veoable/plugin-api --external @veoable/observability",
    "dev": "tsup src/index.ts --format esm --dts --external @veoable/schema --external @veoable/plugin-api --external @veoable/observability --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@veoable/observability": "workspace:*",
    "@veoable/plugin-api": "workspace:*",
    "@veoable/schema": "workspace:*"
  },
  "devDependencies": {
    "@veoable/graph-db": "workspace:*",
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  }
}
