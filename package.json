{
  "name": "veoable",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --project tests",
    "lint": "eslint packages/",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\"",
    "veoable": "node packages/cli/dist/cli.js",
    "install-cli": "pnpm build && pnpm --filter @veoable/cli exec pnpm link --global",
    "uninstall-cli": "pnpm --filter @veoable/cli exec pnpm unlink --global"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^9.0.0",
    "prettier": "^3.9.5",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
