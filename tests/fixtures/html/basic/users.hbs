<!DOCTYPE html>
<html>
<body>
  <h1>{{title}}</h1>

  <form action="/api/users" method="POST">
    <input type="text" name="email" />
    <button type="submit">Create</button>
  </form>

  {{#each users}}
    <div>
      {{name}}
      <button onclick="deleteUser('{{id}}')">Delete</button>
    </div>
  {{/each}}
</body>
</html>
