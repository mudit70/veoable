datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Implicit many-to-many: neither side has an `@relation(fields, references)`
// attribute and neither declares an explicit FK scalar column. Prisma
// materializes the join table itself. Both navigation fields must be
// recognized as relations via the "fieldType is a declared model" rule,
// and must NOT be emitted as DatabaseColumn nodes.
model Post {
  id    Int    @id @default(autoincrement())
  title String
  tags  Tag[]
}

model Tag {
  id    Int    @id @default(autoincrement())
  name  String
  posts Post[]
}
